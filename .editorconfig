root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{s,asm}]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{c,h}]
indent_style = space
indent_size = 4
max_line_length = 100

[Makefile]
indent_style = tab
indent_size = 2

[*.ld]
indent_style = space
indent_size = 2

[*.bat]
indent_style = space
indent_size = 2
end_of_line = crlf

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off
